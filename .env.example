# HermesWith Environment Configuration
# Copy this file to .env and fill in your actual values

# Agent Configuration
AGENT_ID=agent-001
COMPANY_ID=default
AGENT_ROLE=assistant
AGENT_MODEL=k2p5
AGENT_BASE_URL=https://api.kimi.com/coding/v1
AGENT_API_KEY=your-kimi-api-key-here
AGENT_TOOLSETS=terminal,file,web
AGENT_MAX_ITERATIONS=20

# LLM Provider API Keys (at least one required)
KIMI_API_KEY=your-kimi-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database
DATABASE_URL=postgresql://hermeswith:***@postgres:5432/hermeswith

# Redis
REDIS_URL=redis://localhost:6379/0

# Control Plane
CONTROL_PLANE_WS=ws://localhost:8000/ws

# Workspace
WORKSPACE_DIR=/workspace
