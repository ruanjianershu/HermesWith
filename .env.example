# Example environment configuration for Hermeswith
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hermeswith

# Clawith Integration
CLAWITH_BASE_URL=http://localhost:3000
CLAWITH_API_KEY=your_clawith_api_key_here

# Security
RATE_LIMIT_PER_MINUTE=60

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3008

# Server
HOST=0.0.0.0
PORT=8000

# Application
DEBUG=false
LOG_LEVEL=INFO
