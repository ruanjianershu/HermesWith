FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy HermesWith source
COPY pyproject.toml /app/
COPY hermeswith/ /app/hermeswith/

# Copy vendor hermes-agent (real files, not symlink)
COPY vendor/hermes-agent-copy /app/vendor/hermes-agent

# Install Python dependencies
RUN pip install --no-cache-dir -e /app

# Also install hermes-agent dependencies (in case not all are in pyproject.toml)
RUN pip install --no-cache-dir \
    anthropic>=0.25.0 \
    openai>=1.12.0 \
    httpx>=0.26.0 \
    pydantic>=2.6.0 \
    python-dotenv>=1.0.0 \
    redis>=5.0.0 \
    rich>=13.0.0 \
    tenacity>=8.0.0 \
    prompt_toolkit>=3.0.0 \
    pyyaml>=6.0.0 \
    jinja2>=3.1.0 \
    requests>=2.31.0 \
    PyJWT[crypto]>=2.8.0 \
    debugpy>=1.8.0 \
    edge-tts>=6.1.0 \
    croniter>=1.4.0

ENV PYTHONPATH=/app:/app/vendor/hermes-agent

CMD ["python", "-m", "hermeswith.runtime.main"]
