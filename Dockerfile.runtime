FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy HermesWith source
COPY pyproject.toml /app/
COPY hermeswith/ /app/hermeswith/

# Link vendor hermes-agent (assumes it's mounted or copied)
COPY vendor/hermes-agent /app/vendor/hermes-agent

# Install Python dependencies
RUN pip install --no-cache-dir -e /app

# Also install hermes-agent dependencies
RUN pip install --no-cache-dir \
    anthropic>=0.25.0 \
    openai>=1.12.0 \
    httpx>=0.26.0 \
    pydantic>=2.6.0 \
    python-dotenv>=1.0.0 \
    redis>=5.0.0

ENV PYTHONPATH=/app:/app/vendor/hermes-agent

CMD ["python", "-m", "hermeswith.runtime.main"]
